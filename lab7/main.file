import java.util.Arrays;

public class Task12 {
    public static void main(String[] args) {
        int[] B=new int[25];

        for(int i=0;i<25;i++)
            B[i]=(int)(Math.random()*100);

        Arrays.sort(B);
        System.out.println(Arrays.toString(B));
    }
}

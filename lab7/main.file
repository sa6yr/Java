public class Task13 {
    public static void main(String[] args) {
        int[] C=new int[20];
        int sum=0;

        for(int i=0;i<20;i++){
            C[i]=(int)(Math.random()*50);
            sum+=C[i];
        }
        System.out.println("Орта="+(double)sum/20);
    }
}
14.
public class Task14 {
    public static void main(String[] args) {
        int[] D=new int[30];
        int even=0,odd=0;

        for(int i=0;i<30;i++){
            D[i]=(int)(Math.random()*50);
            if(D[i]%2==0)
                even+=D[i];
            else
                odd+=D[i];
        }
        System.out.println("Жұп="+even);
        System.out.println("Тақ="+odd);
    }
}
